DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=bcl_api
# Auto-applies destructive DDL on startup. Forced off in production (see
# src/configs/database.ts); only takes effect in non-production environments.
DB_SYNC=false

DISABLE_MDW_SYNC=false

REDIS_HOST=localhost
REDIS_PORT=6379
# Optional. Only set this for custom deployments that use an authenticated
# external Redis; the bundled compose Redis is localhost-only and has no
# password.
REDIS_PASSWORD=

# ae_uat, ae_mainnet
AE_NETWORK_ID=ae_mainnet

APP_PORT=3000
# Comma-separated list of browser origins allowed to call the API.
# Leave empty (the default) to allow every origin — this API is public
# and consumed by third-party explorers/dashboards, and it has no cookie
# auth to protect. Only set this for private deployments where you want
# to restrict browser callers; when set, CORS `credentials` is also
# enabled so cookie-based integrations can work.
# Example: ALLOWED_ORIGINS=https://superhero.com,https://app.superhero.com
ALLOWED_ORIGINS=

# Trending tags API key to be used for authentication from the scraper.
# Must be a high-entropy random value (>= 32 chars) in production.
TRENDING_TAGS_API_KEY=

PROFILE_X_INVITE_MILESTONE_THRESHOLD=10
PROFILE_X_INVITE_MILESTONE_REWARD_AMOUNT_AE=0
PROFILE_X_INVITE_MILESTONE_REWARD_PRIVATE_KEY=
PROFILE_X_INVITE_LINK_BASE_URL=

# AENS sponsored chain name claiming
PROFILE_CHAIN_NAME_PRIVATE_KEY=

# AddressLink contract – REQUIRED for linking/unlinking external accounts
# (X, etc.) to an AE address. Without these the link/unlink endpoints return
# 503 "AddressLink contract is not configured".
ADDRESS_LINK_SECRET_KEY=
ADDRESS_LINK_CONTRACT_ADDRESS=

# X (Twitter) OAuth 2.0 – user-context login, used ONLY by the address link
# claim/verify flow (Authorization Code + PKCE). These alone are NOT enough to
# read tweets/followers for the reward program.
X_CLIENT_ID=
X_CLIENT_SECRET=

# X (Twitter) App API Key & Secret (consumer keys). REQUIRED by the X reward
# program: the backend mints an app-only Bearer token from these to read user
# profiles, follower counts and tweets. Without them the reward checks cannot
# call the X API and the feature will not work. (Found in the X developer
# portal under your App's "Keys and tokens" → "Consumer Keys".)
# Note: the X v2 user-timeline/lookup endpoints require a paid tier (Basic+).
X_API_KEY=
X_API_KEY_SECRET=

# --- X reward program v2 (referral links, per-post rewards, streak bonus) -----
# Master kill-switch over ALL profile reward payouts. Defaults to true
# (disabled) for safety; set to false to arm payouts. Enabling spends real AE
# from the configured reward wallets. Each *_ENABLED flag below ALSO has to be
# true for its specific reward to pay.
PROFILE_REWARDS_DISABLED=true
#
# Master toggle for the X reward flow + the (capped) post scan.
PROFILE_X_POSTING_REWARD_ENABLED=true
PROFILE_X_POSTING_REWARD_ENABLE_POST_FETCH=false
# Hard cap: at most one X API scan per address per N hours (abuse/cost guard).
PROFILE_X_REWARD_DAILY_CAP_HOURS=24
# Minimum X follower count required to participate in any of the rewards.
PROFILE_X_REWARD_MIN_FOLLOWERS=100

# Path 1 – onboarding: verify X + 1 qualifying post (all keywords, or the
# referral link) → one-time reward.
PROFILE_X_ONBOARDING_REWARD_ENABLED=true
PROFILE_X_ONBOARDING_REWARD_AMOUNT_AE=0.05
PROFILE_X_ONBOARDING_REWARD_PRIVATE_KEY=

# Path 2 – per-post: a post carrying the user's referral link earns AE, ranked
# by follower count via the tier table below. Hard-capped at ONE rewarded post
# per X identity per UTC day (DB-enforced), so bulk-posting earns nothing extra.
PROFILE_X_PERPOST_REWARD_ENABLED=false
PROFILE_X_PERPOST_REWARD_PRIVATE_KEY=
# Tier table: comma-separated `minFollowers:amountAe`; highest matching tier wins.
PROFILE_X_FOLLOWER_TIERS=0:0.1,1000:0.5,10000:1,100000:5

# Streak bonus: RECURRING — every N consecutive posting days pays the bonus
# again and the streak counter restarts from zero.
PROFILE_X_REWARD_STREAK_BONUS_ENABLED=false
PROFILE_X_REWARD_STREAK_LENGTH=10
PROFILE_X_REWARD_STREAK_BONUS_AMOUNT_AE=50
PROFILE_X_REWARD_STREAK_BONUS_PRIVATE_KEY=

# Giphy API key – used by the /giphy/search proxy endpoint
GIPHY_API_KEY=

# Expo push notifications
EXPO_ACCESS_TOKEN=

NOTIFICATIONS_ENABLED=false
ANNOUNCEMENTS_ENABLED=false

# Token-gated rooms (NIP-29 / groups_relay)
# Set BOTH TG_RELAY_URL and TG_BOT_NSEC to enable relay duties (room/membership
# publishing). Leave blank to run API + indexer only — useful for local dev/CI.
# All other knobs have safe defaults — see src/token-gated-rooms/config/tgr.config.ts.
# groups_relay websocket endpoint (ws:// or wss://).
TG_RELAY_URL=
# SECRET. Set with TG_RELAY_URL to enable the relay duties. MUST be the relay admin
# key (D7) — the bot provisions rooms and manages membership, which the relay only
# allows for admins.
TG_BOT_NSEC=
# Comma-separated nostr pubkeys (npub or hex) seeded as admins in every room (D9).
TG_ROOM_ADMINS=
# Optional relay-admin pubkey fallback for the Task 08 health-check; only used when
# the relay's NIP-11 omits "pubkey" (groups_relay advertises it, so normally unset).
TG_RELAY_ADMIN_PUBKEY=
# Trigger the eager ~54k-room backfill on boot (requires a configured relay;
# default off → trigger explicitly). Runs in onApplicationBootstrap (after the app
# is fully up). The 5-min provisioning cron covers steady state.
TG_BACKFILL_ON_BOOT=false
# Rooms per eager-backfill page. Hard-capped at 100 (an over-cap value falls back
# to the default) so a page can't saturate the DB pool. 1..100, default 100.
TG_BACKFILL_BATCH_SIZE=100
# Delay (ms) between eager-backfill pages — paces the sweep so back-to-back pages
# don't sustain DB/relay pressure. 0 chains immediately. default 1000.
TG_BACKFILL_PAGE_DELAY_MS=1000
# Tokens provisioned per tick of the 5-min roomless-token cron (room_id IS NULL).
# Hard-capped at 100 (over-cap falls back to default). 1..100, default 100.
TG_ROOM_PROVISION_BATCH=100
