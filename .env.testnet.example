# Use this when running the app on the HOST while the testnet stack is up
# (docker compose -f docker-compose-testnet.yml up -d).
# Copy to .env or run: npm run start:prod (with these vars loaded).
# Ports match docker-compose-testnet.yml defaults: Postgres 5437, Redis 6380.

DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5437
DB_USER=testnet
DB_PASSWORD=testnet
DB_DATABASE=api_testnet2
# Destructive: auto-applies DDL on startup; forced off in production.
DB_SYNC=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6380

AE_NETWORK_ID=ae_uat
APP_PORT=3000

# Optional: profile / trending / X (same as .env.example)
TRENDING_TAGS_API_KEY=
PROFILE_REGISTRY_CONTRACT_ADDRESS=
PROFILE_ATTESTATION_SIGNER_ADDRESS=
PROFILE_ATTESTATION_PRIVATE_KEY=
X_CLIENT_ID=
X_CLIENT_SECRET=
